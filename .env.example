# Runtime
NODE_ENV=dev
PORT=3000
CORS_ORIGIN=http://localhost:3000

# Databases
mongo_DB=mongodb://localhost:27017/split-dev
prod_mongo_DB=mongodb://localhost:27017/split-prod

# Session / wallet auth
secretKey=replace-me
WALLET_AUTH_DOMAIN=example.invalid
MERCHANT_WALLET_AUTH_DOMAIN=merchant.example.invalid
MESSAGING_IDENTITY_DOMAIN=example.invalid
MESSAGING_PUSH_ENV=dev

# Privacy and encryption secrets
# Generate high-entropy independent values for each deployed environment.
USER_DATA_PEPPER=replace-me
MESSAGING_DATA_PEPPER=replace-me
MESSAGING_BINDING_ENCRYPTION_KEY=replace-me-32-byte-hex-or-base64
PAYOUT_DESTINATION_ENCRYPTION_KEY=replace-me-32-byte-hex-or-base64
PUSH_TOKEN_ENCRYPTION_KEY=replace-me-32-byte-hex-or-base64
PUSH_TOKEN_LOOKUP_PEPPER=replace-me

# Breez / wallet services
BREEZ_API_KEY=replace-me

# Reward claim encryption
# Generate with:
# node -e "const crypto=require('crypto'); const key=crypto.createECDH('prime256v1'); key.generateKeys(); console.log(key.getPrivateKey().toString('base64'))"
REWARD_CLAIM_ECDH_PRIVATE_KEY_BASE64=
REWARD_CLAIM_KEY_ID=reward-claims-dev

# Object storage (Cloudflare R2 or S3-compatible)
R2_ENDPOINT=https://example-account-id.r2.cloudflarestorage.com
R2_BUCKET=split-dev
R2_ACCESS_KEY=replace-me
R2_SECRET_KEY=replace-me

# Push notifications - APNs
APNS_TOPIC=com.example.app.Split-Rewards
APNS_KEY_ID=replace-me
APNS_TEAM_ID=replace-me
APNS_PRIVATE_KEY=
APNS_PRIVATE_KEY_PATH=
APNS_USE_SANDBOX=true

# Push notifications - FCM
FCM_PROJECT_ID=replace-me
FCM_CLIENT_EMAIL=firebase-adminsdk@example.iam.gserviceaccount.com
FCM_PRIVATE_KEY=

# Landing pages / public links
PUBLIC_BASE_URL=https://example.invalid
APP_STORE_URL=https://apps.apple.com/app/id0000000000
PLAY_STORE_URL=https://play.google.com/store/apps/details?id=com.example.android&pcampaignid=web_share
ANDROID_APK_URL=https://cdn.example.invalid/android/split-release.apk
ANDROID_APK_VERSION=0.0.0
ANDROID_APK_SHA256=replace-me

# Optional local tunneling
Ngrok_On=false
NGROK_AUTHTOKEN=
