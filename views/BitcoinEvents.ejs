<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
  <meta http-equiv="X-UA-Compatible" content="IE=edge" />
  <title>Split | Bitcoin Events</title>
  <meta
    name="description"
    content="Find nearby Bitcoin meetups, talks, workshops, and community events in Split."
  />

  <link rel="stylesheet" href="/css/BitcoinEvents.css" type="text/css" />
  <script src="https://unpkg.com/lucide@latest"></script>
  <script defer src="/js/BitcoinEvents.js"></script>
</head>
<body>
  <div class="events-page">
    <header class="events-header">
      <a href="/UserLanding" class="brand-mark" aria-label="Split home">
        <img src="/Split-images/token_logo.png" alt="Split" class="brand-mark__logo" />
        <span class="brand-mark__text">Split</span>
      </a>

      <div class="events-title">
        <p class="events-title__kicker">Bitcoin Events</p>
        <h1>Hang out with your local Bitcoin community.</h1>
      </div>
    </header>

    <main class="events-shell" data-events-page>
      <section class="events-toolbar" aria-label="Bitcoin event search controls">
        <button class="zip-button" type="button" data-zip-open>
          <i data-lucide="hash"></i>
          <span>Use ZIP Code</span>
        </button>

        <div class="mode-toggle" role="tablist" aria-label="Event list mode">
          <button
            class="mode-toggle__button is-active"
            type="button"
            role="tab"
            aria-selected="true"
            data-mode="nearby"
          >
            Nearby
          </button>
          <button
            class="mode-toggle__button"
            type="button"
            role="tab"
            aria-selected="false"
            data-mode="all"
          >
            All Events
          </button>
        </div>
      </section>

      <p class="search-origin" data-search-origin hidden></p>

      <section class="events-list" aria-live="polite" data-events-list>
        <article class="state-card">
          <h2>Enter a ZIP code to find nearby Bitcoin events.</h2>
          <p>We will show events within 25 miles.</p>
        </article>
      </section>
    </main>
  </div>

  <div class="zip-modal" data-zip-modal hidden>
    <div class="zip-modal__backdrop" data-zip-cancel></div>
    <section
      class="zip-sheet"
      role="dialog"
      aria-modal="true"
      aria-labelledby="zip-sheet-title"
    >
      <h2 id="zip-sheet-title">Enter ZIP Code</h2>
      <p>
        Enter your ZIP code and we will show Bitcoin events within 25 miles.
      </p>

      <form class="zip-form" data-zip-form novalidate>
        <label class="zip-field">
          <span>ZIP code</span>
          <input
            type="text"
            inputmode="numeric"
            autocomplete="postal-code"
            placeholder="ZIP code"
            maxlength="10"
            data-zip-input
          />
        </label>

        <p class="zip-error" data-zip-error hidden></p>

        <div class="zip-actions">
          <button class="zip-actions__button zip-actions__button--ghost" type="button" data-zip-cancel>
            Cancel
          </button>
          <button class="zip-actions__button zip-actions__button--primary" type="submit" data-zip-submit>
            Show Events
          </button>
        </div>
      </form>
    </section>
  </div>
</body>
</html>
