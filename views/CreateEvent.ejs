<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta http-equiv="X-UA-Compatible" content="IE=edge" />
  <title>Create Bitcoin Event | Split</title>
  <meta name="robots" content="noindex,nofollow" />
  <link rel="stylesheet" href="/css/CreateEvent.css" type="text/css" />
</head>
<body>
  <main class="page">
    <section class="event-card">
      <div class="brand-lockup">
        <img src="/Split-images/token_logo.png" alt="Split logo" class="brand-lockup__logo" />
        <span>Split</span>
      </div>

      <% if (!configured) { %>
        <p class="eyebrow">Configuration Required</p>
        <h1>Event importer is unavailable.</h1>
        <p class="intro">
          Set the EVENT_PW environment variable before using this page.
        </p>
      <% } else if (!isAuthenticated) { %>
        <p class="eyebrow">Private Event Import</p>
        <h1>Enter password.</h1>
        <p class="intro">
          This session lasts 45 minutes. After that, the page will ask for the password again.
        </p>

        <% if (authError) { %>
          <div class="banner banner--error" role="alert">
            <%= authError %>
          </div>
        <% } %>

        <form action="/createEvent/login" method="POST" class="event-form">
          <label class="field">
            <span>Password</span>
            <input
              type="password"
              name="eventPassword"
              autocomplete="current-password"
              autofocus
              required
            />
          </label>

          <button type="submit" class="submit-button">Unlock Event Import</button>
        </form>
      <% } else { %>
        <div class="event-card__header">
          <div>
            <p class="eyebrow">Bitcoin Events</p>
            <h1>Import Luma event.</h1>
            <p class="intro">
              Paste a Luma event URL and Split will create or update the Bitcoin event record.
            </p>
          </div>

          <form action="/createEvent/logout" method="POST">
            <button type="submit" class="ghost-button">Lock</button>
          </form>
        </div>

        <div class="session-pill" role="status">
          Password session expires in about <%= remainingMinutes %> minutes.
        </div>

        <% if (formError) { %>
          <div class="banner banner--error" role="alert">
            <%= formError %>
          </div>
        <% } %>

        <% if (importedEvent) { %>
          <%
            const startDate = importedEvent.startsAt ? new Date(importedEvent.startsAt) : null;
            let startsAtText = 'Date TBD';
            if (startDate && !Number.isNaN(startDate.getTime())) {
              const dateOptions = {
                dateStyle: 'medium',
                timeStyle: 'short',
              };

              if (importedEvent.timezone) {
                dateOptions.timeZone = importedEvent.timezone;
              }

              try {
                startsAtText = startDate.toLocaleString('en-US', dateOptions);
              } catch (_error) {
                startsAtText = startDate.toLocaleString('en-US', {
                  dateStyle: 'medium',
                  timeStyle: 'short',
                });
              }
            }
            const locationParts = [
              importedEvent.venueName,
              importedEvent.city,
              importedEvent.region,
            ].filter(Boolean);
          %>
          <div class="banner banner--success" role="status">
            <%= created ? 'Event created.' : 'Event updated.' %>
          </div>

          <div class="result-panel">
            <h2><%= importedEvent.title %></h2>
            <dl class="event-summary">
              <div>
                <dt>Source</dt>
                <dd><a href="<%= importedEvent.sourceUrl %>" target="_blank" rel="noopener noreferrer"><%= importedEvent.sourceUrl %></a></dd>
              </div>
              <div>
                <dt>Starts</dt>
                <dd><%= startsAtText %></dd>
              </div>
              <div>
                <dt>Location</dt>
                <dd><%= locationParts.join(', ') || 'Location TBD' %></dd>
              </div>
              <div>
                <dt>Host</dt>
                <dd><%= importedEvent.hostName || 'Host TBD' %></dd>
              </div>
            </dl>
          </div>
        <% } %>

        <form action="/createEvent" method="POST" class="event-form">
          <label class="field">
            <span>Luma event URL</span>
            <input
              type="url"
              name="eventUrl"
              value="<%= values.eventUrl %>"
              placeholder="https://lu.ma/example"
              inputmode="url"
              autocomplete="off"
              required
            />
          </label>

          <div class="event-form__footer">
            <p class="footnote">
              Only US, in-person Luma events with usable event data can be imported.
            </p>
            <button type="submit" class="submit-button">Create Event</button>
          </div>
        </form>
      <% } %>
    </section>
  </main>
</body>
</html>
