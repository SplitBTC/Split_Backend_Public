<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta http-equiv="X-UA-Compatible" content="IE=edge" />
  <title>Split | Bitcoin Rewards Wallet</title>
  <meta
    name="description"
    content="Split is a Bitcoin rewards wallet that helps you earn sats for spending Bitcoin."
  />

  <link rel="stylesheet" href="/css/UserLanding.css" type="text/css" />

  <script async src="https://www.googletagmanager.com/gtag/js?id=G-05YTF1Y41D"></script>
  <script>
    window.dataLayer = window.dataLayer || [];
    function gtag() { dataLayer.push(arguments); }
    gtag("js", new Date());
    gtag("config", "G-05YTF1Y41D");
  </script>

  <script src="https://unpkg.com/lucide@latest"></script>
</head>

<body>
  <%
    const s = (typeof stats !== 'undefined' && stats) ? stats : {};
    const appStoreUrl = (typeof APP_STORE_URL !== 'undefined' && APP_STORE_URL)
      ? APP_STORE_URL
      : 'https://apps.apple.com/app/idYOUR_APP_ID';
    const playStoreUrl = (typeof PLAY_STORE_URL !== 'undefined' && PLAY_STORE_URL)
      ? PLAY_STORE_URL
      : 'https://play.google.com/store/apps/details?id=com.splitloyalty.android&pcampaignid=web_share';
    const donation = (typeof donationCard !== 'undefined' && donationCard) ? donationCard : null;

    const usd = (cents) => {
      const v = Number(cents || 0) / 100;
      try {
        return new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD' }).format(v);
      } catch {
        return `$${v.toFixed(2)}`;
      }
    };

    const nfmt = (n) => {
      const v = Math.max(0, Number(n || 0));
      try {
        return new Intl.NumberFormat('en-US').format(v);
      } catch {
        return String(v);
      }
    };

    const btc = (satsVal) => {
      const v = Math.max(0, Number(satsVal || 0)) / 1e8;
      return v.toFixed(8).replace(/\.0+$/, '').replace(/(\.\d*[1-9])0+$/, '$1');
    };
  %>

  <div class="landing-page">
    <header class="hero-shell">
      <nav class="topbar shell">
        <a href="/UserLanding" class="brand-mark" aria-label="Split home">
          <img src="/Split-images/token_logo.png" alt="Split" class="brand-mark__logo" />
          <span class="brand-mark__text">Split</span>
        </a>
      </nav>

      <section class="hero shell">
        <div class="hero__copy">
          <p class="section-kicker">Bitcoin Rewards Wallet</p>

          <h1 class="hero__title">
            Earn <a class="hero__btc hero__btc--pink hero__btc-link" href="/Home" aria-label="Enter the Bitcoin rabbit hole">&#8383;</a> for<br />
            Spending <span class="hero__btc hero__btc--blue">&#8383;</span>
          </h1>

          <p class="hero__rotator" aria-live="polite">
            <span class="hero__rotator-text is-visible" data-hero-rotator>Are you paying attention?</span>
          </p>

          <div class="hero__cta">
            <a
              class="btn btn--primary btn--store btn--large"
              href="<%= appStoreUrl %>"
              target="_blank"
              rel="noopener"
              aria-label="Download Split for iOS on the App Store"
            >
              <svg class="btn__icon btn__icon--apple" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                <path d="M16.88 12.77c-.02-2.24 1.84-3.32 1.92-3.37-1.05-1.53-2.67-1.74-3.24-1.76-1.37-.14-2.69.81-3.38.81-.71 0-1.78-.79-2.93-.77-1.5.02-2.89.87-3.66 2.22-1.58 2.73-.4 6.76 1.12 8.97.76 1.08 1.64 2.29 2.79 2.25 1.12-.05 1.54-.72 2.89-.72 1.34 0 1.73.72 2.91.69 1.21-.02 1.96-1.09 2.69-2.18.87-1.24 1.22-2.45 1.23-2.51-.03-.01-2.31-.88-2.34-3.63Z" />
                <path d="M14.67 6.18c.61-.75 1.03-1.77.91-2.8-.88.04-1.98.61-2.61 1.34-.56.65-1.07 1.71-.93 2.7.99.08 2-.5 2.63-1.24Z" />
              </svg>
              iOS
            </a>
            <a
              class="btn btn--android btn--store btn--large"
              href="<%= playStoreUrl %>"
              target="_blank"
              rel="noopener"
              aria-label="Download Split for Android on Google Play"
            >
              <svg class="btn__icon btn__icon--android" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                <path d="M7.15 9.85h9.7v7.09c0 .73-.59 1.32-1.32 1.32h-.9v1.91c0 .55-.45 1-1 1s-1-.45-1-1v-1.91h-1.26v1.91c0 .55-.45 1-1 1s-1-.45-1-1v-1.91h-.9c-.73 0-1.32-.59-1.32-1.32V9.85Z" />
                <path d="M17.04 8.8H6.96c.18-1.48 1.1-2.75 2.37-3.42L8.46 3.84a.45.45 0 0 1 .78-.44l.91 1.62a6.07 6.07 0 0 1 3.7 0l.91-1.62a.45.45 0 0 1 .78.44l-.87 1.54A4.82 4.82 0 0 1 17.04 8.8Z" />
                <path d="M5.4 10.19c.55 0 1 .45 1 1v4.6c0 .55-.45 1-1 1s-1-.45-1-1v-4.6c0-.55.45-1 1-1Z" />
                <path d="M18.6 10.19c.55 0 1 .45 1 1v4.6c0 .55-.45 1-1 1s-1-.45-1-1v-4.6c0-.55.45-1 1-1Z" />
                <path d="M9.97 7.1a.47.47 0 1 1-.94 0 .47.47 0 0 1 .94 0Z" />
                <path d="M14.97 7.1a.47.47 0 1 1-.94 0 .47.47 0 0 1 .94 0Z" />
              </svg>
              Android
            </a>
          </div>
        </div>

      </section>
    </header>

    <main class="shell main-shell">
      <section class="stats-section" id="stats" aria-label="Platform stats">
        <div class="section-head">
          <div>
            <p class="section-kicker">Platform Stats</p>
            <h2 class="section-title">Live rewards and traction from real Bitcoin commerce.</h2>
          </div>

          <div class="section-head__aside">
            <p class="section-head__meta">
              Updated from current platform activity for <span><%= s.monthKey || "this month" %></span>.
            </p>

            <button class="btn btn--ghost rewards-info-button" type="button" data-rewards-modal-open>
              Bitcoin Rewards Program
            </button>
          </div>
        </div>

        <div class="stats-grid">
          <article class="stat-card stat-card--hero">
            <span class="stat-card__label">Current Reward Pot</span>
            <strong class="stat-card__value"><%= nfmt(s.currentMonthlyRewardPotSats) %> sats</strong>
            <span class="stat-card__sub"><%= btc(s.currentMonthlyRewardPotSats) %> BTC</span>
          </article>

          <article class="stat-card">
            <span class="stat-card__label">Bitcoin Rewarded All Time</span>
            <strong class="stat-card__value"><%= nfmt(s.satsRewardedAllTime) %> sats</strong>
            <span class="stat-card__sub"><%= btc(s.satsRewardedAllTime) %> BTC</span>
          </article>

          <article class="stat-card">
            <span class="stat-card__label">Merchant Spend This Month</span>
            <strong class="stat-card__value"><%= usd(s.totalMerchantSpendMonthUsdCents) %></strong>
            <span class="stat-card__sub"><%= nfmt(s.totalTransactionsMonth) %> verified merchant transactions</span>
          </article>

          <article class="stat-card">
            <span class="stat-card__label">Lifetime Merchant Spend</span>
            <strong class="stat-card__value"><%= usd(s.lifetimeMerchantSpendUsdCents) %></strong>
            <span class="stat-card__sub"><%= nfmt(s.lifetimeTransactions) %> lifetime merchant transactions</span>
          </article>
        </div>
      </section>

      <section class="foss-teaser" aria-label="Split open source repositories">
        <div class="foss-teaser__copy">
          <h2 class="section-title">Open Source</h2>
          <p class="foss-teaser__text">
            We do our best to keep our public repos updated and maintained. We encourage and welcome your scrutiny and critiques.
          </p>
        </div>

        <div class="foss-teaser__actions">
          <a class="btn btn--ghost" href="/foss-projects">Open Source Repos</a>
        </div>
      </section>

      <section class="donation-section" aria-label="Support the rewards pot">
        <div class="donation-section__copy">
          <p class="section-kicker">Support the Pot</p>
          <h2 class="section-title">Donate Bitcoin directly to the rewards pot.</h2>
          <p class="spotlight__text">
            Want to help grow Split rewards? Scan the wallet QR code or send Bitcoin to the Lightning
            address below to contribute directly to the rewards pot.
          </p>

          <% if (donation && donation.lightningAddress) { %>
            <div class="donation-address-card">
              <span class="donation-address-card__label">Lightning Address</span>
              <strong class="donation-address-card__value"><%= donation.lightningAddress %></strong>
            </div>
          <% } %>
        </div>

        <article class="donation-qr-card">
          <div class="donation-qr-card__badge">Bitcoin Rewards Pot</div>
          <% if (donation && donation.qrCodeDataUrl) { %>
            <img
              src="<%= donation.qrCodeDataUrl %>"
              alt="QR code for donating to the Split rewards pot"
              class="donation-qr-card__image"
              loading="lazy"
            />
          <% } %>
          <p class="donation-qr-card__caption">
            Scan with any Lightning wallet to send sats to the Split rewards pot.
          </p>
        </article>
      </section>

    </main>

    <footer class="footer shell">
      <div class="footer__brand">
        <img src="/Split-images/token_logo.png" alt="" class="footer__logo" />
        <span>Split</span>
      </div>

      <nav class="footer__links">
        <a href="/foss-projects">Open Source Repos</a>
        <a href="/User-agreement" target="_blank" rel="noopener">User Agreement</a>
        <a href="/Privacy-policy" target="_blank" rel="noopener">Privacy Policy</a>
      </nav>
    </footer>

    <div class="rewards-modal" data-rewards-modal hidden>
      <div class="rewards-modal__backdrop" data-rewards-modal-close></div>

      <section
        class="rewards-modal__panel"
        role="dialog"
        aria-modal="true"
        aria-labelledby="rewards-modal-title"
      >
        <button class="rewards-modal__close" type="button" aria-label="Close rewards program details" data-rewards-modal-close>
          <i data-lucide="x"></i>
        </button>

        <p class="section-kicker">Our Bitcoin Rewards Program</p>
        <h2 id="rewards-modal-title">How Rewards Work</h2>

        <div class="rewards-modal__copy">
          <p>Each month, Split sets aside Bitcoin in a rewards pool that’s paid out at the end of the month.</p>
          <p>You earn a share of the Bitcoin pool based on the Bitcoin you spend with verified merchants.</p>
          <p>You get credited for all of the Bitcoin you spend with verified merchants.</p>
          <p>Your Bitcoin reward is determined by your percentage of spend relative to the platform. If you account for 5% of the platform's reward eligible spending, you receive 5% of the Bitcoin rewards pot.</p>
          <p>As reward eligible spend grows, we will grow the size of the Bitcoin rewards pool. Our goal is simple: Drive real world Bitcoin transactions.</p>
          <p>If you have any questions, comments, suggestions, or concerns please reach out to taylor@split-loyalty.com</p>
        </div>

        <article class="rewards-modal__note">
          <div class="rewards-modal__note-icon"><i data-lucide="bolt"></i></div>
          <div>
            <h3>Reward Eligible Spend</h3>
            <p>Rewards are based on Bitcoin spent with verified merchants.</p>
          </div>
        </article>

        <article class="rewards-modal__disclaimer">
          <h3>Disclaimer</h3>
          <p>Rewards are discretionary and can change over time. Lightning payments are generally final. Bitcoin value is volatile, The rewards pool is a set Bitcoin amount. The fiat value (USD) will shift up or down throughout the month.</p>
        </article>
      </section>
    </div>
  </div>

  <script>
    document.querySelectorAll('a[href^="#"]').forEach((anchor) => {
      anchor.addEventListener("click", (event) => {
        const id = anchor.getAttribute("href");
        if (id && id.length > 1) {
          event.preventDefault();
          document.querySelector(id)?.scrollIntoView({ behavior: "smooth" });
        }
      });
    });

    const rewardsModal = document.querySelector("[data-rewards-modal]");
    const rewardsModalOpen = document.querySelector("[data-rewards-modal-open]");
    const rewardsModalCloseButtons = document.querySelectorAll("[data-rewards-modal-close]");

    function openRewardsModal() {
      if (!rewardsModal) return;
      rewardsModal.hidden = false;
      document.body.classList.add("is-modal-open");
      rewardsModal.querySelector(".rewards-modal__close")?.focus();
    }

    function closeRewardsModal() {
      if (!rewardsModal) return;
      rewardsModal.hidden = true;
      document.body.classList.remove("is-modal-open");
      rewardsModalOpen?.focus();
    }

    rewardsModalOpen?.addEventListener("click", openRewardsModal);
    rewardsModalCloseButtons.forEach((button) => {
      button.addEventListener("click", closeRewardsModal);
    });

    document.addEventListener("keydown", (event) => {
      if (event.key === "Escape" && rewardsModal && !rewardsModal.hidden) {
        closeRewardsModal();
      }
    });

    const heroRotator = document.querySelector("[data-hero-rotator]");
    const heroPhrases = [
      "Are you paying attention?",
      "You want to know what Bitcoin really is?",
      "You tap the Blue Bitcoin Logo",
      "The story ends and",
      "you stay on this generic landing page",
      "You tap the Pink Bitcoin Logo",
      "you stay in wonderland and",
      "you see how deep the rabbithole goes",
    ];

    if (heroRotator && !window.matchMedia("(prefers-reduced-motion: reduce)").matches) {
      let heroPhraseIndex = 0;

      window.setInterval(() => {
        heroPhraseIndex = (heroPhraseIndex + 1) % heroPhrases.length;
        heroRotator.classList.remove("is-visible");
        heroRotator.classList.add("is-exiting");

        window.setTimeout(() => {
          heroRotator.textContent = heroPhrases[heroPhraseIndex];
          heroRotator.classList.remove("is-exiting");
          heroRotator.classList.add("is-entering");

          window.requestAnimationFrame(() => {
            heroRotator.classList.remove("is-entering");
            heroRotator.classList.add("is-visible");
          });
        }, 220);
      }, 2400);
    }

    lucide.createIcons({
      attrs: {
        width: 20,
        height: 20,
        stroke: "currentColor",
        "stroke-width": 2,
      },
    });
  </script>
</body>
</html>
